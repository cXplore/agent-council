{
  "name": "agent-council",
  "version": "0.1.0",
  "description": "Run structured meetings between your Claude Code agents. Watch them deliberate in real time.",
  "author": "cXplore",
  "license": "MIT",
  "repository": "cXplore/agent-council",
  "main": "electron/main.js",
  "bin": {
    "agent-council": "./bin/cli.js"
  },
  "scripts": {
    "dev": "next dev -p 3003 -H 127.0.0.1",
    "build": "next build",
    "start": "next start -p 3003 -H 127.0.0.1",
    "lint": "eslint",
    "electron:dev": "electron .",
    "electron:build": "next build && electron-builder",
    "electron:start": "electron .",
    "dist": "next build && electron-builder --publish never",
    "dist:win": "next build && electron-builder --win --publish never",
    "dist:mac": "next build && electron-builder --mac --publish never",
    "dist:linux": "next build && electron-builder --linux --publish never"
  },
  "dependencies": {
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "zod": "^4.3.6"
  },
  "build": {
    "appId": "com.agent-council.app",
    "productName": "Agent Council",
    "directories": {
      "output": "dist-electron"
    },
    "asar": false,
    "files": [
      "electron/**/*",
      ".next/**/*",
      "node_modules/**/*",
      "public/**/*",
      "templates/**/*",
      "meetings/**/*",
      "agents/**/*",
      "council.config.json",
      "package.json",
      "next.config.ts"
    ],
    "forceCodeSigning": false,
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/icon.png",
      "category": "Development"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  }
}
