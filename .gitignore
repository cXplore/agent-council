# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# config (user-specific, auto-created with defaults)
council.config.json
.council-planned.json

# electron
/dist-electron/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# meetings (generated during use, don't commit user meetings)
/meetings/*.md
!/meetings/example-*.md

# runtime state (generated by the app, never commit)
/meetings/.council-*.json
.council-activity.jsonl
.council-worker-log.md
.council-worker-state.json

# tool caches
.playwright-mcp/

# screenshots from walkthroughs/UX audits
ux-*.png
walkthrough-*.png
page-*.png

# claude
.claude/
.env.local
